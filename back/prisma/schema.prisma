// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SkillMastery {
  NOT_PROFICIENT
  PROFICIENT
  EXPERTISE
}

enum DndSkillName {
  ACROBATICS
  ANIMAL_HANDLING
  ARCANA
  ATHLETICS
  DECEPTION
  HISTORY
  INSIGHT
  INTIMIDATION
  INVESTIGATION
  MEDICINE
  NATURE
  PERCEPTION
  PERFORMANCE
  PERSUASION
  RELIGION
  SLEIGHT_OF_HAND
  STEALTH
  SURVIVAL
}

// Types d'objets insérés dans init.sql (table item_types).
// Le champ ItemType.name reste String pour permettre d'autres types (ex. via POST /api/items/types).
enum ItemTypeName {
  Arme
  Armure
  Bouclier
  Objet_magique @map("Objet magique")
  Potion
  Parchemin
  Gemme
  Outils
  Vetement @map("Vêtement")
  Nourriture
  Autre
}

enum AbilityName {
  STRENGTH
  DEXTERITY
  CONSTITUTION
  INTELLIGENCE
  WISDOM
  CHARISMA
}

enum CharacterFeatureCategory {
  CLASS_FEATURE
  RACIAL_TRAIT
  FEAT
  PERSONALITY_AND_BACKGROUND
  OTHER_PROFICIENCIES_AND_LANGUAGES
}

// Modèle User
model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  email        String   @unique
  passwordHash String
  isActive     Boolean  @default(true)
  roleId       Int
  role         Role     @relation(fields: [roleId], references: [id])
  characters   Character[]
  campaigns    Campaign[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}

// Modèle Role
model Role {
  id    Int    @id @default(autoincrement())
  name  String @unique
  users User[]

  @@map("roles")
}

// Modèle Character
model Character {
  id              Int      @id @default(autoincrement())
  userId          Int
  user            User     @relation(fields: [userId], references: [id])
  name            String
  race            String?
  class           String?
  level           Int?
  background      String?
  alignment       String?
  experiencePoints Int     @default(0)
  hitPoints       Int?
  currentHitPoints Int?
  hitDice         String?
  hitDiceRemaining Int?
  armorClass      Int?
  speed           Int?
  strength        Int?
  dexterity       Int?
  constitution    Int?
  intelligence    Int?
  wisdom          Int?
  charisma        Int?
  description     String?
  notes           String?
  isActive        Boolean  @default(true)
  skills          CharacterSkill[]
  savingThrows    CharacterSavingThrow[]
  spellSlots      CharacterSpellSlot[]
  grimoire        Grimoire[]
  inventory       Inventory[]
  equipment       Equipment[]
  dnd5eInventory  CharacterDnd5eInventory[]
  purse           Purse?
  features        CharacterFeature[]
  campaignCharacters CampaignCharacter[]
  sessionAttendance SessionAttendance[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("characters")
}

model CharacterFeature {
  id          Int      @id @default(autoincrement())
  characterId Int
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  category    CharacterFeatureCategory
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("character_features")
}

// Emplacements de sorts par niveau (0-9)
model CharacterSpellSlot {
  id          Int      @id @default(autoincrement())
  characterId Int
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  level       Int
  slotsMax    Int      @default(0)
  slotsUsed   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([characterId, level])
  @@map("character_spell_slots")
}

model CharacterSkill {
  id          Int          @id @default(autoincrement())
  characterId Int
  character   Character    @relation(fields: [characterId], references: [id])
  skill       DndSkillName
  mastery     SkillMastery @default(NOT_PROFICIENT)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([characterId, skill])
  @@map("character_skills")
}

model CharacterSavingThrow {
  id          Int        @id @default(autoincrement())
  characterId Int
  character   Character  @relation(fields: [characterId], references: [id], onDelete: Cascade)
  ability     AbilityName
  proficient  Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([characterId, ability])
  @@map("character_saving_throws")
}

// Types de base documentés par enum ItemTypeName (même jeu que init.sql).
model ItemType {
  id          Int    @id @default(autoincrement())
  name        String @unique
  description String?
  // Legacy (plus utilisé après alignement Item<->Dnd5eEquipment)
  // items       Item[]

  @@map("item_types")
}

// Modèle Item
model Item {
  id          Int      @id @default(autoincrement())
  // Aligné sur Dnd5eEquipment (dnd5eapi.co)
  index       String   @unique
  name        String
  type        Dnd5eEquipmentType @default(other)
  category    String?
  subcategory String?

  cost        String?
  weight      Int?
  description String?

  damage      String?
  damageType  String?
  range       String?

  armorClass          Int?
  stealthDisadvantage Boolean?

  properties Json?
  raw        Json?

  isActive    Boolean  @default(true)
  inventory   Inventory[]
  equipment   Equipment[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("items")
}

// Modèle EquipmentSlot
model EquipmentSlot {
  id          Int    @id @default(autoincrement())
  name        String @unique
  description String?
  equipment   Equipment[]

  @@map("equipment_slots")
}

// Modèle Inventory
model Inventory {
  id          Int      @id @default(autoincrement())
  characterId Int
  character   Character @relation(fields: [characterId], references: [id])
  itemId      Int
  item        Item     @relation(fields: [itemId], references: [id])
  quantity    Int      @default(1)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([characterId, itemId])
  @@map("character_inventory")
}

// Modèle Equipment
model Equipment {
  id          Int           @id @default(autoincrement())
  characterId Int
  character   Character     @relation(fields: [characterId], references: [id])
  itemId      Int
  item        Item          @relation(fields: [itemId], references: [id])
  slotId      Int
  slot        EquipmentSlot @relation(fields: [slotId], references: [id])
  isEquipped  Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Un enregistrement par objet (item) équipé : plusieurs armes / armures / gear possibles (slot souvent « Autre »).
  @@unique([characterId, itemId])
  @@map("character_equipment")
}

// Modèle Purse (colonnes alignées sur init.sql / character_purse)
model Purse {
  id               Int      @id @default(autoincrement())
  characterId      Int      @unique @map("character_id")
  character        Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  copperPieces     Int      @default(0) @map("copper_pieces")
  silverPieces     Int      @default(0) @map("silver_pieces")
  electrumPieces   Int      @default(0) @map("electrum_pieces")
  goldPieces       Int      @default(0) @map("gold_pieces")
  platinumPieces   Int      @default(0) @map("platinum_pieces")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("character_purse")
}

// Modèle Campaign
model Campaign {
  id            Int      @id @default(autoincrement())
  gmId          Int
  gm            User     @relation(fields: [gmId], references: [id])
  name          String
  description   String?
  setting       String?
  maxPlayers    Int      @default(4)
  currentPlayers Int     @default(0)
  status        String   @default("active")
  startDate     DateTime?
  endDate       DateTime?
  notes         String?
  isActive      Boolean  @default(true)
  characters    CampaignCharacter[]
  sessions      GameSession[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("campaigns")
}

// Modèle GameSession
model GameSession {
  id          Int      @id @default(autoincrement())
  campaignId  Int
  campaign    Campaign @relation(fields: [campaignId], references: [id])
  sessionNumber Int
  title       String
  description String?
  sessionDate String   // YYYY-MM-DD format
  startTime   String?  // HH:MM format
  endTime     String?  // HH:MM format
  location    String?
  notes       String?
  xpAwarded   Int      @default(0)
  goldAwarded Float    @default(0)
  isActive    Boolean  @default(true)
  attendance  SessionAttendance[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("game_sessions")
}

// Modèle CampaignCharacter
model CampaignCharacter {
  id          Int      @id @default(autoincrement())
  campaignId  Int
  campaign    Campaign @relation(fields: [campaignId], references: [id])
  characterId Int
  character   Character @relation(fields: [characterId], references: [id])
  currentHitPoints Int?
  hitDiceRemaining Int?
  joinedAt    DateTime @default(now())
  leftAt      DateTime?
  status      String   @default("active")
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([campaignId, characterId])
  @@map("campaign_characters")
}

// Modèle SessionAttendance
model SessionAttendance {
  id          Int      @id @default(autoincrement())
  sessionId   Int
  session     GameSession @relation(fields: [sessionId], references: [id])
  characterId Int
  character   Character @relation(fields: [characterId], references: [id])
  attended    Boolean  @default(false)
  xpEarned    Int      @default(0)
  goldEarned  Float    @default(0)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([sessionId, characterId])
  @@map("session_attendance")
}

// Modèle Grimoire
model Grimoire {
  id          Int      @id @default(autoincrement())
  characterId Int
  character   Character @relation(fields: [characterId], references: [id])
  // Copie locale d'un sort (permet doublons de noms / index)
  spellId     Int
  spell       Spell    @relation(fields: [spellId], references: [id], onDelete: Cascade)
  isPrepared  Boolean  @default(false)
  isKnown     Boolean  @default(true)
  timesPrepared Int    @default(0)
  timesCast   Int      @default(0)
  notes       String?
  learnedAt   DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("character_grimoire")
}

// === D&D 5e Spells (dnd5eapi.co) ===
model Dnd5eSpellImport {
  id            Int      @id @default(autoincrement())
  index         String   @unique
  name          String
  level         Int?
  school        String?
  castingTime   String?
  range         String?
  components    String?
  duration      String?
  description   String?
  higherLevel   String?
  ritual        Boolean?
  concentration Boolean?
  raw           Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("dnd5e_spells_import")
}

model Spell {
  id            Int      @id @default(autoincrement())
  index         String   @unique
  name          String
  level         Int?
  school        String?
  castingTime   String?
  range         String?
  components    String?
  duration      String?
  description   String?
  higherLevel   String?
  ritual        Boolean?
  concentration Boolean?
  source        String? // 'dnd5e' | 'custom'
  raw           Json?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  grimoireEntries Grimoire[]

  @@map("spells")
}

model DndMonster {
  id              Int      @id @default(autoincrement())
  slug            String   @unique
  name            String
  size            String?
  type            String?
  subtype         String?
  alignment       String?
  armorClass      Int?
  hitPoints       Int?
  hitDice         String?
  speed           String?
  strength        Int?
  dexterity       Int?
  constitution    Int?
  intelligence    Int?
  wisdom          Int?
  charisma        Int?
  challengeRating String?
  xp              Int?
  description     String?
  createdAt       DateTime @default(now())

  @@map("dnd_monsters")
}

model DndWeapon {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  name        String
  category    String?
  weaponType  String?
  damage      String?
  damageType  String?
  properties  String?
  weight      Float?
  cost        String?
  description String?
  createdAt   DateTime @default(now())

  @@map("dnd_weapons")
}

model DndArmor {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  name        String
  category    String?
  armorType   String?
  armorClass  Int?
  strength    Int?
  stealth     String?
  weight      Float?
  cost        String?
  description String?
  createdAt   DateTime @default(now())

  @@map("dnd_armor")
}

// === D&D 5e Equipment (dnd5eapi.co) ===
enum Dnd5eEquipmentType {
  weapon
  armor
  gear
  tool
  mount
  vehicle
  ammunition
  consumable
  other
}

model Dnd5eEquipment {
  id          Int      @id @default(autoincrement())
  index       String   @unique
  name        String
  type        Dnd5eEquipmentType @default(other)
  category    String?
  subcategory String?

  cost        String?
  weight      Int?
  description String?

  // Champs spécifiques (nullable)
  damage      String?
  damageType  String?
  range       String?

  armorClass          Int?
  stealthDisadvantage Boolean?

  properties Json?
  raw        Json?

  inventories CharacterDnd5eInventory[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("dnd5e_equipment")
}

model CharacterDnd5eInventory {
  id          Int      @id @default(autoincrement())
  characterId Int
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  equipmentId Int
  equipment   Dnd5eEquipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  quantity    Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([characterId, equipmentId])
  @@map("character_dnd5e_inventory")
}
