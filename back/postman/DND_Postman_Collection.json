    {
      "name": "D&D API Info",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/dnd/info",
          "host": ["{{baseUrl}}"],
          "path": ["api", "dnd", "info"]
        }
      },
      "response": []
    },
