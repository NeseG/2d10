{
  "info": {
    "name": "2d10 D&D API Collection",
    "description": "Collection pour les routes D&D intégrées avec Open5e",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
